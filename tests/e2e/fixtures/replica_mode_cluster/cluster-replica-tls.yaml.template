apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: cluster-replica-tls
spec:
  instances: 3

  bootstrap:
    pg_basebackup:
      source: cluster-replica-src

  replica:
    enabled: true
    source: cluster-replica-src

  postgresql:
    parameters:
      log_checkpoints: "on"
      log_lock_waits: "on"
      log_min_duration_statement: '0'
      log_statement: 'all'
      log_temp_files: '1024'
      log_autovacuum_min_duration: '1s'
      log_replication_commands: 'on'
      log_connections: 'on'
      log_disconnections: 'on'
      log_min_messages: 'DEBUG3'
      wal_receiver_timeout: '2s'
      wal_retrieve_retry_interval: '2s'

  storage:
    size: 1Gi
    storageClass: ${E2E_DEFAULT_STORAGE_CLASS}

  externalClusters:
  - name: cluster-replica-src
    connectionParameters:
      host: cluster-replica-src-rw
      user: streaming_replica
      sslmode: verify-full
      dbname: postgres
      port: "5432"
    sslKey:
      name: cluster-replica-src-replication
      key: tls.key
    sslCert:
      name: cluster-replica-src-replication
      key: tls.crt
    sslRootCert:
      name: cluster-replica-src-ca
      key: ca.crt
